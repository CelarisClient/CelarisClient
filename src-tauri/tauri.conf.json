{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Celaris Launcher",
  "version": "0.1.1",
  "identifier": "com.celaris.launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Celaris Launcher",
        "width": 1040,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "visible": false
      },
      {
        "label": "splashscreen",
        "url": "splashscreen.html",
        "title": "Celaris",
        "width": 440,
        "height": 320,
        "decorations": false,
        "center": true,
        "resizable": false,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Game",
    "shortDescription": "Celaris – Minecraft Client & Launcher",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/CelarisClient/CelarisClient/releases/latest/download/latest.json",
        "https://api.celarisclient.de/content/launcher/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVFNDBCMDVDMEU0RTNGNTYKUldSV1AwNE9YTEJBWGt5b3poelkzUzR4UEE5bHh5bTM5bGFvUUxBSTNSelRyZ25FcytMeFJJdzkK"
    }
  }
}